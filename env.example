# ── PTM (MyPTM) ───────────────────────────────────────────────────────────────
PTM_USERNAME=your_ptm_username
PTM_PASSWORD=your_ptm_password

# ── Gallagher ────────────────────────────────────────────────────────────────
GALLAGHER_FARM_ID=your_farm_id
GALLAGHER_USERNAME=your_gallagher_username
GALLAGHER_PASSWORD=your_gallagher_password

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID_3=your_chat_id

# ── Email alert (Outlook) ─────────────────────────────────────────────────────
# MAIL_SEND: địa chỉ gửi đi (shared mailbox hoặc cá nhân)
MAIL_SEND=
# MAIL_TO và MAIL_CC: phân cách bằng dấu phẩy
MAIL_TO= 
MAIL_CC=
# Email nhận cảnh báo hệ thống
ALERT_MAIL_TO=

# ── telegram_token.env (tách riêng, đặt tại D:\PYTHON_TOOLS\env\telegram_token.env) ──
TELEGRAM_BOT_TOKEN_INFOR=your_bot_token
TELEGRAM_CHAT_ID=         # TESTING DATA
TELEGRAM_CHAT_ID_2=     # DAILY REPORT
TELEGRAM_CHAT_ID_INFO=     # INFO PRODUCTION GROUP
TELEGRAM_CHAT_ID_VET=      # VET GROUP

# ── Backfill (set per-run, không cần lưu trong file) ──────────────────────────
# $env:DATE_FROM="2026-04-17"; $env:DATE_TO="2026-04-28"; python main.py
DATE_FROM=
DATE_TO=

# ── Device toggle (mặc định true) ────────────────────────────────────────────
ENABLE_CIMA1=true
ENABLE_CIMA2=true
ENABLE_GALLAGHER1=true

# ── Raw parse only (không gọi API, đọc raw CSV từ disk) ──────────────────────
RAW_PARSE_ONLY=false

# ── QC thresholds ─────────────────────────────────────────────────────────────
HERD_JOIN_ALERT_THRESHOLD=0.30
HERD_JOIN_MIN_ROWS=20
